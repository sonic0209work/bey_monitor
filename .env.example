# 複製這個檔案為 .env 並填入你的憑證。未設定的通知管道會自動略過。

# --- 監控目標（預設已指向 funbox 戰鬥陀螺分類，通常不需要改） ---
# CATEGORY_JSON_URL=https://shop.funbox.com.tw/category_products/XI/KB.json
# CATEGORY_PAGE_URL=https://shop.funbox.com.tw/categories/XI/KB

# --- LINE Messaging API（LINE Notify 已於 2025-03-31 停用，需改用官方帳號） ---
# 1. 到 https://developers.line.biz/console/ 建立 Provider + Messaging API Channel
# 2. 取得 Channel access token（長期）
# 3. 用該官方帳號加你自己為好友，取得你的 userId（可從 webhook 或官方帳號後台的「一對一聊天」查詢）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# --- Telegram ---
# 1. 跟 @BotFather 對話 /newbot 建立機器人，取得 token
# 2. 跟你的機器人隨便傳一則訊息，再打開
#    https://api.telegram.org/bot<token>/getUpdates 找到 chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (Gmail SMTP，需先在 Google 帳號開啟兩步驟驗證並建立應用程式密碼) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sonic0209work@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=sonic0209work@gmail.com
EMAIL_TO=sonic0209work@gmail.com
